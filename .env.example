# Database (Neon Postgres)
SPRING_DATASOURCE_URL=jdbc:postgresql://your-host.neon.tech/neondb?sslmode=require
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=your-password-here

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# JWT
JWT_SECRET_KEY=your-base64-encoded-secret-key
JWT_EXPIRATION=900000
JWT_COOKIE_NAME=jwt-cookie
JWT_COOKIE_MAX_AGE=86400

# Frontend — base URL of the Railway backend (set in Vercel env vars)
VITE_API_BASE_URL=https://your-backend.up.railway.app

# Frontend — base URL used to display short links in the UI
VITE_SHORT_BASE_URL=https://your-short-domain.com

# Frontend — API endpoint overrides (defaults used if not set)
VITE_SHORTEN_ENDPOINT=/api/v1/shorten
VITE_DASHBOARD_ENDPOINT=/api/v1/dashboard
VITE_STATS_BASE_ENDPOINT=/api/v1/stats
VITE_LINKS_BASE_ENDPOINT=/api/v1/links

# Docker Compose only — proxy target for local development
VITE_API_PROXY_TARGET=http://backend:8080